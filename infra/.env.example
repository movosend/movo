# Env para infra/docker-compose.yml en local (ver docker-compose.local.yml).
# En dev/prod estas variables las genera el workflow de CI/CD leyendo
# AWS Secrets Manager (movo/<env>/app-secrets) — nunca se commitean.

POSTGRES_USER=movo
POSTGRES_PASSWORD=movo_local_pw
DATABASE_URL=postgresql://movo:movo_local_pw@postgres:5432/movo
JWT_SECRET=local_dev_jwt_secret
MERCADOPAGO_ACCESS_TOKEN=test_token
API_DOMAIN=localhost
IMAGE_TAG=local
